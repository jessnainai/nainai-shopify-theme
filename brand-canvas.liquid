{% comment %}
  NAINAI x OFYSINA — Flexible Canvas Section
  Replace contents of: sections/brand-canvas.liquid

  A full-bleed "canvas" section where each child block (image, text,
  decorative SVG, spacer) is absolutely positioned via an anchor point
  (left/center/right × top/middle/bottom) plus an X/Y percentage nudge.
  This lets the merchant match any Figma layout from the theme editor
  without touching code — add blocks, pick an anchor, slide the
  X/Y/width ranges until it matches the design.

  Companion asset:
    • assets/brand-canvas.css
{% endcomment %}

{{ 'brand-canvas.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign content_max = section.settings.content_max_width
  if content_max == 0 or content_max == blank
    assign content_max_css = '100%'
  else
    assign content_max_css = content_max | append: 'px'
  endif
-%}

<section
  class="brand-canvas"
  id="brand-canvas-{{ section.id }}"
  style="
    --bc-bg: {{ section.settings.bg_color | default: '#F5F0E6' }};
    --bc-text: {{ section.settings.text_color | default: '#3B2A1A' }};
    --bc-overlay: {{ section.settings.overlay_color | default: '#000000' }};
    --bc-overlay-opacity: {{ section.settings.overlay_opacity | default: 0 | divided_by: 100.0 }};
    --bc-min-height-desktop: {{ section.settings.min_height_desktop }}px;
    --bc-min-height-mobile: {{ section.settings.min_height_mobile }}px;
    --bc-pad-top-desktop: {{ section.settings.top_space_desktop }}px;
    --bc-pad-bottom-desktop: {{ section.settings.bottom_space_desktop }}px;
    --bc-pad-top-mobile: {{ section.settings.top_space_mobile }}px;
    --bc-pad-bottom-mobile: {{ section.settings.bottom_space_mobile }}px;
    --bc-content-max: {{ content_max_css }};
  "
>
  {%- if section.settings.bg_image != blank -%}
    <img
      class="brand-canvas__bg"
      src="{{ section.settings.bg_image | image_url: width: 2400 }}"
      srcset="{{ section.settings.bg_image | image_url: width: 800 }} 800w, {{ section.settings.bg_image | image_url: width: 1400 }} 1400w, {{ section.settings.bg_image | image_url: width: 2000 }} 2000w, {{ section.settings.bg_image | image_url: width: 2400 }} 2400w"
      sizes="100vw"
      width="{{ section.settings.bg_image.width }}"
      height="{{ section.settings.bg_image.height }}"
      alt=""
      loading="lazy"
      aria-hidden="true"
    >
  {%- endif -%}

  {%- if section.settings.overlay_opacity > 0 -%}
    <div class="brand-canvas__overlay" aria-hidden="true"></div>
  {%- endif -%}

  <div class="brand-canvas__stage">

    {%- for block in section.blocks -%}
      {%- liquid
        assign h_anchor = block.settings.h_anchor | default: 'center'
        assign v_anchor = block.settings.v_anchor | default: 'middle'

        case h_anchor
          when 'left'
            assign h_pos = '0%'
            assign h_translate = '0%'
          when 'center'
            assign h_pos = '50%'
            assign h_translate = '-50%'
          when 'right'
            assign h_pos = '100%'
            assign h_translate = '-100%'
        endcase

        case v_anchor
          when 'top'
            assign v_pos = '0%'
            assign v_translate = '0%'
          when 'middle'
            assign v_pos = '50%'
            assign v_translate = '-50%'
          when 'bottom'
            assign v_pos = '100%'
            assign v_translate = '-100%'
        endcase

        assign x_offset = block.settings.x_offset | default: 0
        assign y_offset = block.settings.y_offset | default: 0
        assign z_index = block.settings.z_index | default: 5
        assign hide_mobile = block.settings.hide_on_mobile | default: false
        assign hide_desktop = block.settings.hide_on_desktop | default: false
      -%}

      <div
        class="
          brand-canvas__block
          brand-canvas__block--{{ block.type }}
          brand-canvas__block--h-{{ h_anchor }}
          brand-canvas__block--v-{{ v_anchor }}
          {% if hide_mobile %}brand-canvas__block--hide-mobile{% endif %}
          {% if hide_desktop %}brand-canvas__block--hide-desktop{% endif %}
        "
        style="
          --bc-h-pos: {{ h_pos }};
          --bc-v-pos: {{ v_pos }};
          --bc-h-translate: {{ h_translate }};
          --bc-v-translate: {{ v_translate }};
          --bc-x-offset: {{ x_offset }}%;
          --bc-y-offset: {{ y_offset }}%;
          --bc-z: {{ z_index }};
          {%- if block.settings.width_desktop -%}--bc-width-desktop: {{ block.settings.width_desktop }}%;{%- endif -%}
          {%- if block.settings.width_mobile -%}--bc-width-mobile: {{ block.settings.width_mobile }}%;{%- endif -%}
        "
        {{ block.shopify_attributes }}
      >

        {%- case block.type -%}

          {%- when 'image' -%}
            {%- if block.settings.image != blank -%}
              <img
                class="brand-canvas__image"
                src="{{ block.settings.image | image_url: width: 1800 }}"
                srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 800 }} 800w, {{ block.settings.image | image_url: width: 1200 }} 1200w, {{ block.settings.image | image_url: width: 1800 }} 1800w"
                sizes="(max-width: 989px) {{ block.settings.width_mobile | default: 80 }}vw, {{ block.settings.width_desktop | default: 40 }}vw"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                alt="{{ block.settings.image.alt | default: block.settings.image_alt | escape }}"
                loading="lazy"
                style="
                  object-fit: {{ block.settings.object_fit | default: 'contain' }};
                  {%- if block.settings.aspect_ratio != blank and block.settings.aspect_ratio != 'natural' -%}
                    aspect-ratio: {{ block.settings.aspect_ratio }};
                  {%- endif -%}
                "
              >
            {%- else -%}
              <div class="brand-canvas__image-placeholder">{{ 'image' | placeholder_svg_tag: 'brand-canvas__placeholder-svg' }}</div>
            {%- endif -%}

          {%- when 'text' -%}
            <div
              class="brand-canvas__text brand-canvas__text--align-{{ block.settings.text_alignment | default: 'center' }}"
              style="
                color: {{ block.settings.text_color | default: section.settings.text_color | default: '#3B2A1A' }};
                {%- if block.settings.text_background != blank and block.settings.text_background != 'transparent' -%}
                  background-color: {{ block.settings.text_background }};
                {%- endif -%}
                {%- if block.settings.text_padding -%}
                  padding: {{ block.settings.text_padding }}px;
                {%- endif -%}
              "
            >
              {%- if block.settings.eyebrow != blank -%}
                <p class="brand-canvas__eyebrow">{{ block.settings.eyebrow }}</p>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h2
                  class="brand-canvas__heading"
                  style="font-size: {{ block.settings.heading_size | default: 36 }}px;"
                >
                  {{ block.settings.heading }}
                </h2>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
                <div
                  class="brand-canvas__body rte"
                  style="font-size: {{ block.settings.body_size | default: 16 }}px;"
                >
                  {{ block.settings.body }}
                </div>
              {%- endif -%}
              {%- if block.settings.caption != blank -%}
                <p class="brand-canvas__caption">{{ block.settings.caption }}</p>
              {%- endif -%}
              {%- if block.settings.btn_label != blank -%}
                <a
                  class="brand-canvas__btn"
                  href="{{ block.settings.btn_link | default: '#' }}"
                  style="
                    color: {{ block.settings.btn_color | default: '#ffffff' }};
                    background-color: {{ block.settings.btn_bg | default: '#8B5A3C' }};
                  "
                >
                  {{ block.settings.btn_label }}
                </a>
              {%- endif -%}
            </div>

          {%- when 'decorative' -%}
            {%- if block.settings.decor_image != blank -%}
              <img
                class="brand-canvas__decor"
                src="{{ block.settings.decor_image | image_url: width: 1400 }}"
                srcset="{{ block.settings.decor_image | image_url: width: 400 }} 400w, {{ block.settings.decor_image | image_url: width: 800 }} 800w, {{ block.settings.decor_image | image_url: width: 1400 }} 1400w"
                sizes="{{ block.settings.width_desktop | default: 30 }}vw"
                width="{{ block.settings.decor_image.width }}"
                height="{{ block.settings.decor_image.height }}"
                alt=""
                loading="lazy"
                aria-hidden="true"
                style="object-fit: contain;"
              >
            {%- else -%}
              {%- assign dot_color = block.settings.decor_color | default: '#8B5A3C' -%}
              <svg
                class="brand-canvas__decor brand-canvas__decor--svg"
                viewBox="0 0 400 400"
                preserveAspectRatio="xMidYMid meet"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                focusable="false"
              >
                {%- case block.settings.decor_preset -%}
                  {%- when 'dot-cluster' -%}
                    <g fill="{{ dot_color }}">
                      <circle cx="80"  cy="120" r="4"/><circle cx="120" cy="100" r="3"/><circle cx="160" cy="130" r="5"/>
                      <circle cx="200" cy="110" r="3"/><circle cx="240" cy="140" r="4"/><circle cx="280" cy="120" r="5"/>
                      <circle cx="320" cy="150" r="3"/><circle cx="100" cy="160" r="4"/><circle cx="140" cy="170" r="3"/>
                      <circle cx="180" cy="180" r="5"/><circle cx="220" cy="170" r="4"/><circle cx="260" cy="180" r="3"/>
                      <circle cx="300" cy="190" r="4"/><circle cx="130" cy="210" r="3"/><circle cx="170" cy="220" r="5"/>
                      <circle cx="210" cy="210" r="4"/><circle cx="250" cy="225" r="3"/><circle cx="290" cy="215" r="4"/>
                      <circle cx="150" cy="250" r="3"/><circle cx="190" cy="260" r="4"/><circle cx="230" cy="255" r="5"/>
                      <circle cx="270" cy="265" r="3"/><circle cx="180" cy="290" r="4"/><circle cx="220" cy="295" r="3"/>
                      <circle cx="60"  cy="180" r="3"/><circle cx="340" cy="170" r="4"/><circle cx="90"  cy="240" r="3"/>
                      <circle cx="310" cy="240" r="4"/><circle cx="110" cy="280" r="3"/><circle cx="290" cy="285" r="4"/>
                    </g>
                  {%- when 'curve-trail' -%}
                    <path d="M 40 340 Q 120 300 180 240 T 320 80" fill="none" stroke="{{ dot_color }}" stroke-width="3" stroke-linecap="round"/>
                    <circle cx="40"  cy="340" r="6" fill="{{ dot_color }}"/>
                    <circle cx="180" cy="240" r="6" fill="{{ dot_color }}"/>
                    <circle cx="320" cy="80"  r="6" fill="{{ dot_color }}"/>
                  {%- when 'circle-ring' -%}
                    <circle cx="200" cy="200" r="150" fill="none" stroke="{{ dot_color }}" stroke-width="2"/>
                    <circle cx="200" cy="200" r="110" fill="none" stroke="{{ dot_color }}" stroke-width="1" stroke-dasharray="4 6"/>
                    <circle cx="200" cy="200" r="6" fill="{{ dot_color }}"/>
                  {%- else -%}
                    <g fill="{{ dot_color }}">
                      <circle cx="140" cy="140" r="5"/><circle cx="200" cy="120" r="5"/><circle cx="260" cy="140" r="5"/>
                      <circle cx="140" cy="200" r="5"/><circle cx="200" cy="200" r="8"/><circle cx="260" cy="200" r="5"/>
                      <circle cx="140" cy="260" r="5"/><circle cx="200" cy="280" r="5"/><circle cx="260" cy="260" r="5"/>
                    </g>
                {%- endcase -%}
              </svg>
            {%- endif -%}

          {%- when 'spacer' -%}
            <div
              class="brand-canvas__spacer"
              style="height: {{ block.settings.spacer_height | default: 40 }}px;"
              aria-hidden="true"
            ></div>

        {%- endcase -%}
      </div>
    {%- endfor -%}

  </div>
</section>

{% schema %}
{
  "name": "NAINAI Canvas",
  "tag": "section",
  "class": "section-brand-canvas",
  "settings": [
    {
      "type": "header",
      "content": "Canvas background"
    },
    {
      "type": "paragraph",
      "content": "The canvas is a full-bleed section. Add blocks below and position each with anchor + X/Y nudge to match your Figma design."
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image (full-bleed)",
      "info": "Fills the entire section edge-to-edge. Use a high-res image (2400px+)."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color (fallback)",
      "default": "#F5F0E6"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Default text color",
      "default": "#3B2A1A"
    },
    {
      "type": "header",
      "content": "Canvas size"
    },
    {
      "type": "range",
      "id": "min_height_desktop",
      "label": "Min height (desktop)",
      "min": 300,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "min_height_mobile",
      "label": "Min height (mobile)",
      "min": 200,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Canvas max width",
      "info": "Set to 0 for full-bleed (no max width).",
      "min": 0,
      "max": 2400,
      "step": 20,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "Top space (desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "Bottom space (desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "Top space (mobile)",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "Bottom space (mobile)",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "limit": 10,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Alt text (optional, for accessibility)"
        },
        {
          "type": "select",
          "id": "object_fit",
          "label": "Fit",
          "options": [
            { "value": "contain", "label": "Contain (show whole image)" },
            { "value": "cover",   "label": "Cover (fill & crop)" }
          ],
          "default": "contain"
        },
        {
          "type": "select",
          "id": "aspect_ratio",
          "label": "Aspect ratio",
          "options": [
            { "value": "natural", "label": "Natural" },
            { "value": "1 / 1",   "label": "Square" },
            { "value": "4 / 3",   "label": "4 : 3" },
            { "value": "3 / 4",   "label": "3 : 4" },
            { "value": "16 / 9",  "label": "16 : 9" },
            { "value": "9 / 16",  "label": "9 : 16" }
          ],
          "default": "natural"
        },
        {
          "type": "header",
          "content": "Position"
        },
        {
          "type": "select",
          "id": "h_anchor",
          "label": "Horizontal anchor",
          "options": [
            { "value": "left",   "label": "Left edge" },
            { "value": "center", "label": "Center" },
            { "value": "right",  "label": "Right edge" }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "v_anchor",
          "label": "Vertical anchor",
          "options": [
            { "value": "top",    "label": "Top edge" },
            { "value": "middle", "label": "Middle" },
            { "value": "bottom", "label": "Bottom edge" }
          ],
          "default": "middle"
        },
        {
          "type": "range",
          "id": "x_offset",
          "label": "X offset (nudge)",
          "info": "Slide left (−) or right (+) from the anchor.",
          "min": -100,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 0
        },
        {
          "type": "range",
          "id": "y_offset",
          "label": "Y offset (nudge)",
          "info": "Slide up (−) or down (+) from the anchor.",
          "min": -100,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 0
        },
        {
          "type": "range",
          "id": "width_desktop",
          "label": "Width (desktop)",
          "min": 5,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 30
        },
        {
          "type": "range",
          "id": "width_mobile",
          "label": "Width (mobile)",
          "min": 10,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 60
        },
        {
          "type": "range",
          "id": "z_index",
          "label": "Layer (z-index)",
          "min": 1,
          "max": 20,
          "step": 1,
          "default": 5
        },
        {
          "type": "checkbox",
          "id": "hide_on_mobile",
          "label": "Hide on mobile",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "hide_on_desktop",
          "label": "Hide on desktop",
          "default": false
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 10,
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow (small label above heading)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "range",
          "id": "heading_size",
          "label": "Heading size",
          "min": 14,
          "max": 96,
          "step": 2,
          "unit": "px",
          "default": 40
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body"
        },
        {
          "type": "range",
          "id": "body_size",
          "label": "Body size",
          "min": 12,
          "max": 32,
          "step": 1,
          "unit": "px",
          "default": 16
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (small text below body)"
        },
        {
          "type": "select",
          "id": "text_alignment",
          "label": "Text alignment",
          "options": [
            { "value": "left",   "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right",  "label": "Right" }
          ],
          "default": "center"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color"
        },
        {
          "type": "color",
          "id": "text_background",
          "label": "Text background color (optional)"
        },
        {
          "type": "range",
          "id": "text_padding",
          "label": "Text padding",
          "min": 0,
          "max": 80,
          "step": 2,
          "unit": "px",
          "default": 0
        },
        {
          "type": "header",
          "content": "Button (optional)"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button link"
        },
        {
          "type": "color",
          "id": "btn_bg",
          "label": "Button background",
          "default": "#8B5A3C"
        },
        {
          "type": "color",
          "id": "btn_color",
          "label": "Button text color",
          "default": "#FFFFFF"
        },
        {
          "type": "header",
          "content": "Position"
        },
        {
          "type": "select",
          "id": "h_anchor",
          "label": "Horizontal anchor",
          "options": [
            { "value": "left",   "label": "Left edge" },
            { "value": "center", "label": "Center" },
            { "value": "right",  "label": "Right edge" }
          ],
          "default": "center"
        },
        {
          "type": "select",
          "id": "v_anchor",
          "label": "Vertical anchor",
          "options": [
            { "value": "top",    "label": "Top edge" },
            { "value": "middle", "label": "Middle" },
            { "value": "bottom", "label": "Bottom edge" }
          ],
          "default": "middle"
        },
        {
          "type": "range",
          "id": "x_offset",
          "label": "X offset (nudge)",
          "min": -100,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 0
        },
        {
          "type": "range",
          "id": "y_offset",
          "label": "Y offset (nudge)",
          "min": -100,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 0
        },
        {
          "type": "range",
          "id": "width_desktop",
          "label": "Max width (desktop)",
          "min": 10,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 40
        },
        {
          "type": "range",
          "id": "width_mobile",
          "label": "Max width (mobile)",
          "min": 20,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 85
        },
        {
          "type": "range",
          "id": "z_index",
          "label": "Layer (z-index)",
          "min": 1,
          "max": 20,
          "step": 1,
          "default": 10
        },
        {
          "type": "checkbox",
          "id": "hide_on_mobile",
          "label": "Hide on mobile",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "hide_on_desktop",
          "label": "Hide on desktop",
          "default": false
        }
      ]
    },
    {
      "type": "decorative",
      "name": "Decorative art",
      "limit": 10,
      "settings": [
        {
          "type": "paragraph",
          "content": "Use either your own image (decorative vector/PNG) or pick one of the built-in SVG presets."
        },
        {
          "type": "image_picker",
          "id": "decor_image",
          "label": "Custom image (overrides preset)"
        },
        {
          "type": "select",
          "id": "decor_preset",
          "label": "Built-in SVG preset",
          "options": [
            { "value": "dot-cluster",  "label": "Dot cluster" },
            { "value": "curve-trail",  "label": "Curve trail" },
            { "value": "circle-ring",  "label": "Circle ring" },
            { "value": "dot-grid",     "label": "Dot grid" }
          ],
          "default": "dot-cluster"
        },
        {
