{% comment %}
  NAINAI x OFYSINA — Hero Banner Section
  Matches Figma design: full-bleed hero with text on right, frosted glass CTA
  File: sections/hero-banner.liquid
{% endcomment %}

<style>
  /* ── Satoshi font ── */
  @font-face {
    font-family: 'Satoshi';
    src: url('https://cdn.fontshare.com/wf/YDIKSKGVJXGCDRPZQNULWUBKGY3ELHLF/GFRTWGFIDJ5YFKRUXIIHKDLQK36HO6ML/SDHQMYJ637HXRJG7BQNCJ6EBK5XRDJNL.woff2') format('woff2');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Satoshi';
    src: url('https://cdn.fontshare.com/wf/YDIKSKGVJXGCDRPZQNULWUBKGY3ELHLF/CWXU3RLPHTLFPB7MHSVZDXQBG3YYRFLJ/YJCH5YRWNWQRQLHOBKNP5EK5VWYUHZBI.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Satoshi';
    src: url('https://cdn.fontshare.com/wf/YDIKSKGVJXGCDRPZQNULWUBKGY3ELHLF/I3AZXTSMPVGF6GRSM5TU5HBMKVKIV2FQ/5SRO47A3BUSV6R3BTOQFJKM3FLDVHGDP.woff2') format('woff2');
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }

  /* ── Hero container ── */
  .nainai-hero {
    position: relative;
    width: 100%;
    aspect-ratio: 1440 / 934;
    overflow: hidden;
  }

  /* ── Background image ── */
  .nainai-hero__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    z-index: 0;
  }

  .nainai-hero__bg-placeholder {
    position: absolute;
    inset: 0;
    background: #1e1e1e;
    z-index: 0;
  }

  /* ── Gradient overlay — subtle left, darker right for legibility ── */
  .nainai-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(0, 0, 0, 0.05) 0%,
      rgba(0, 0, 0, 0.05) 40%,
      rgba(0, 0, 0, 0.38) 100%
    );
    z-index: 1;
  }

  /* ── Text content — right half, exact Figma positioning ── */
  .nainai-hero__content {
    position: absolute;
    z-index: 5;
    left: 50%;
    top: 37.3%;
    width: 535px;
  }

  /* ── Heading ── */
  .nainai-hero__heading {
    color: #FFFDF3 !important;
    font-family: 'Satoshi', sans-serif !important;
    font-size: 30px !important;
    font-weight: 700 !important;
    line-height: 0.87 !important;
    letter-spacing: -0.9px !important;
    text-transform: lowercase;
    margin: 0 0 25px !important;
    white-space: nowrap;
  }

  /* ── Body text ── */
  .nainai-hero__body {
    color: #FFFDF3 !important;
    font-family: 'Satoshi', sans-serif !important;
    font-size: 16px !important;
    font-weight: 500 !important;
    line-height: 1.15 !important;
    letter-spacing: -0.48px !important;
    margin: 0 0 14px !important;
    max-width: 486px;
  }

  .nainai-hero__body:last-of-type {
    margin-bottom: 32px !important;
  }

  /* ── Frosted glass CTA button ── */
  .nainai-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 279px;
    height: 51px;
    padding: 0;
    color: #FFFDF3;
    font-family: 'Satoshi', sans-serif;
    font-size: 16px;
    font-weight: 700;
    line-height: 0.87;
    letter-spacing: -0.03em;
    text-decoration: none;
    text-transform: none;
    background: rgba(255, 253, 243, 0.2);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    border: 1px solid rgba(255, 253, 243, 0.15);
    border-radius: 7px;
    transition: background 0.3s ease;
    cursor: pointer;
  }

  .nainai-hero__btn:hover {
    background: rgba(255, 253, 243, 0.32);
    color: #FFFDF3;
    text-decoration: none;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .nainai-hero {
      aspect-ratio: auto;
      height: 100vh;
      min-height: 500px;
    }

    .nainai-hero__content {
      left: 5%;
      right: 5%;
      width: auto;
      max-width: 100%;
      top: auto;
      bottom: 12%;
    }

    .nainai-hero__overlay {
      background: linear-gradient(
        to top,
        rgba(0, 0, 0, 0.55) 0%,
        rgba(0, 0, 0, 0.08) 60%
      );
    }

    .nainai-hero__heading {
      font-size: 22px;
      margin-bottom: 16px;
    }

    .nainai-hero__body {
      font-size: 12px;
    }

    .nainai-hero__body:last-of-type {
      margin-bottom: 24px;
    }

    .nainai-hero__btn {
      min-width: 100%;
      height: 48px;
      font-size: 13px;
    }
  }
</style>

<section class="nainai-hero" aria-label="Hero banner">

  {%- if section.settings.hero_image != blank -%}
    <img
      class="nainai-hero__bg"
      src="{{ section.settings.hero_image | image_url: width: 2400 }}"
      srcset="
        {{ section.settings.hero_image | image_url: width: 800 }} 800w,
        {{ section.settings.hero_image | image_url: width: 1200 }} 1200w,
        {{ section.settings.hero_image | image_url: width: 1800 }} 1800w,
        {{ section.settings.hero_image | image_url: width: 2400 }} 2400w
      "
      sizes="100vw"
      alt="{{ section.settings.hero_image.alt | default: section.settings.heading | default: shop.name }}"
      loading="eager"
      fetchpriority="high"
      width="2400"
      height="934"
    >
  {%- else -%}
    <div class="nainai-hero__bg-placeholder"></div>
  {%- endif -%}

  <div class="nainai-hero__overlay"></div>

  <div class="nainai-hero__content">
    <h1 class="nainai-hero__heading">
      {{ section.settings.heading | default: 'ancient herbal remedies in gummy form' }}
    </h1>

    <p class="nainai-hero__body">
      {{ section.settings.subtext_1 | default: 'Centuries-old plant remedies inspired by Traditional Chinese Medicine (TCM) brewed into a full-spectrum decoction & delivered in an ultra-clean, vegan gummy.' }}
    </p>

    <p class="nainai-hero__body">
      {{ section.settings.subtext_2 | default: 'Used in clinical practice for generations to support immunity, mood, digestion & hormone balance.' }}
    </p>

    <a
      href="{{ section.settings.btn_link | default: '/collections/all' }}"
      class="nainai-hero__btn"
    >
      {{ section.settings.btn_label | default: 'Shop TCM Gummies' }}
    </a>
  </div>

</section>

{% schema %}
{
  "name": "NAINAI Hero Banner",
  "tag": "section",
  "class": "section-hero-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Background Image",
      "info": "Use a high-resolution photo (recommended: 2400 x 934px)."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ancient herbal remedies in gummy form"
    },
    {
      "type": "textarea",
      "id": "subtext_1",
      "label": "Body Text — Paragraph 1",
      "default": "Centuries-old plant remedies inspired by Traditional Chinese Medicine (TCM) brewed into a full-spectrum decoction & delivered in an ultra-clean, vegan gummy."
    },
    {
      "type": "textarea",
      "id": "subtext_2",
      "label": "Body Text — Paragraph 2",
      "default": "Used in clinical practice for generations to support immunity, mood, digestion & hormone balance."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Text",
      "default": "Shop TCM Gummies"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "NAINAI Hero Banner"
    }
  ]
}
{% endschema %}
