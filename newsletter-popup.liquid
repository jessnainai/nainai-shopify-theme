        },
        {
          "label":"t:sections.newsletter-popup.settings.pop_position.center.label",
          "value": "center",
           "group": "Middle"
        },
        {
          "label": "t:sections.newsletter-popup.settings.pop_position.center-right.label",
          "value": "center-right",
           "group": "Middle"
        },
        {
          "label": "t:sections.newsletter-popup.settings.pop_position.bottom-left.label",
          "value": "bottom-left",
