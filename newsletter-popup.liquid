{%  liquid  
assign size = 'small'
if section.settings.image != blank
  if section.settings.image_position == 'top'
    assign size = 'small'
  elsif section.settings.image_position == 'left'
    assign size = 'large'
  elsif section.settings.image_position == 'right'
    assign size = 'large'
  endif
endif
%}
{% render 'popup',
  modal_name: 'newsletter',
  modal_position: section.settings.popup_position,
  modal_size: size,
  popup_color_scheme: section.settings.color_scheme,
  section: section
%}
<script type="text/javascript">
  let login_customer_id = '';
</script>
{% if customer %}
  <script type="text/javascript">
    login_customer_id = '{{ customer.id }}';
  </script>
{% endif %}
<style>
  #shopify-section-{{ section.id }} {
    --image_overlay_opacity: {{ section.settings.overlay_opacity }};
  }
</style>
{% schema %}
{
  "name": "t:sections.newsletter-popup.name",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "class": "newsletter-popup",
