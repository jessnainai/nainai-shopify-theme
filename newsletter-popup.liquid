    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:sections.all.colors.label"
    },
    {
      "type": "select",
      "id":"popup_position",
      "label": "Position",
      "default":"center",
      "options": [
        {
          "label": "t:sections.newsletter-popup.settings.pop_position.center-left.label",
          "value": "center-left",
