{% comment %}
  NAINAI x OFYSINA — Brand Philosophy & Timeline Section
  Replace contents of: sections/brand-timeline.liquid

  Renders a full-width philosophy block with:
    • a hand-drawn ascending line graph (SVG) of 6 brand milestones
    • scroll-triggered "draw" animation (IntersectionObserver + stroke-dashoffset)
    • a heading + body column on the right (desktop) / below (mobile)

  Companion assets:
    • assets/brand-timeline.css
    • assets/brand-timeline.js
{% endcomment %}

{{ 'brand-timeline.css' | asset_url | stylesheet_tag }}

<section
  class="nainai-timeline"
  id="nainai-timeline-{{ section.id }}"
  style="
    --nt-bg: {{ section.settings.bg_color | default: '#F5F0E6' }};
    --nt-text: {{ section.settings.text_color | default: '#3B2A1A' }};
    --nt-line: {{ section.settings.line_color | default: '#8B5A3C' }};
    --nt-top-desktop: {{ section.settings.top_space_desktop }}px;
    --nt-bottom-desktop: {{ section.settings.bottom_space_desktop }}px;
    --nt-top-mobile: {{ section.settings.top_space_mobile }}px;
    --nt-bottom-mobile: {{ section.settings.bottom_space_mobile }}px;
  "
  data-nainai-timeline
>
  {%- if section.settings.bg_image != blank -%}
    <img
      class="nainai-timeline__bg"
      src="{{ section.settings.bg_image | image_url: width: 2400 }}"
      srcset="{{ section.settings.bg_image | image_url: width: 800 }} 800w, {{ section.settings.bg_image | image_url: width: 1400 }} 1400w, {{ section.settings.bg_image | image_url: width: 2000 }} 2000w, {{ section.settings.bg_image | image_url: width: 2400 }} 2400w"
      sizes="100vw"
      width="{{ section.settings.bg_image.width }}"
      height="{{ section.settings.bg_image.height }}"
      alt=""
      loading="lazy"
      aria-hidden="true"
    >
  {%- endif -%}

  <div class="nainai-timeline__inner">

    <div class="nainai-timeline__graph" role="img" aria-label="NaiNai brand milestones, from 2,000 years of tradition to zero sugar">
      <svg
        class="nainai-timeline__svg"
        viewBox="0 0 1600 900"
        preserveAspectRatio="xMidYMid meet"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
        focusable="false"
      >
        <path
          class="nainai-timeline__path"
          d="M 160 780 Q 280 770 400 680 T 640 560 T 900 420 T 1160 290 T 1420 160"
          fill="none"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
          vector-effect="non-scaling-stroke"
        />
        <g class="nainai-timeline__dots">
          <circle class="nainai-timeline__dot" cx="160"  cy="780" r="9" data-index="0"/>
          <circle class="nainai-timeline__dot" cx="400"  cy="680" r="9" data-index="1"/>
          <circle class="nainai-timeline__dot" cx="640"  cy="560" r="9" data-index="2"/>
          <circle class="nainai-timeline__dot" cx="900"  cy="420" r="9" data-index="3"/>
          <circle class="nainai-timeline__dot" cx="1160" cy="290" r="9" data-index="4"/>
          <circle class="nainai-timeline__dot" cx="1420" cy="160" r="9" data-index="5"/>
        </g>
      </svg>

      <ul class="nainai-timeline__labels">
        <li class="nainai-timeline__label nainai-timeline__label--below" style="--x: 10%;    --y: 86.67%;" data-index="0">
          <span class="nainai-timeline__label-text">{{ section.settings.milestone_1 | default: '2,000+ Years of Tradition' | escape }}</span>
        </li>
        <li class="nainai-timeline__label nainai-timeline__label--above" style="--x: 25%;    --y: 75.55%;" data-index="1">
          <span class="nainai-timeline__label-text">{{ section.settings.milestone_2 | default: 'Tested for Purity & Potency' | escape }}</span>
        </li>
        <li class="nainai-timeline__label nainai-timeline__label--below" style="--x: 40%;    --y: 62.22%;" data-index="2">
          <span class="nainai-timeline__label-text">{{ section.settings.milestone_3 | default: 'Formulated by Licensed TCM Herbalists' | escape }}</span>
        </li>
        <li class="nainai-timeline__label nainai-timeline__label--above" style="--x: 56.25%; --y: 46.67%;" data-index="3">
          <span class="nainai-timeline__label-text">{{ section.settings.milestone_4 | default: '100% Vegan' | escape }}</span>
        </li>
        <li class="nainai-timeline__label nainai-timeline__label--below" style="--x: 72.5%;  --y: 32.22%;" data-index="4">
          <span class="nainai-timeline__label-text">{{ section.settings.milestone_5 | default: 'No Artificials / No Added Sugar' | escape }}</span>
        </li>
        <li class="nainai-timeline__label nainai-timeline__label--above" style="--x: 88.75%; --y: 17.78%;" data-index="5">
          <span class="nainai-timeline__label-text">{{ section.settings.milestone_6 | default: 'Zero Sugar' | escape }}</span>
        </li>
      </ul>
    </div>

    {%- if section.settings.heading != blank or section.settings.body != blank -%}
      <div class="nainai-timeline__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="nainai-timeline__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.body != blank -%}
          <div class="nainai-timeline__body rte">{{ section.settings.body }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

<script src="{{ 'brand-timeline.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "NAINAI Brand Timeline",
  "tag": "section",
  "class": "section-brand-timeline",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Rooted in ancient wisdom, made for modern bodies"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body paragraph",
      "default": "<p>In TCM, the body is understood as an integrated whole where mind & body are inseparable. We use the exact herbal pairings and proportions written by ancient herbalists — honoring these original formulas while ensuring every ingredient is something your body recognizes.</p>"
    },
    {
      "type": "header",
      "content": "Timeline milestones (left → right, ascending)"
    },
    {
      "type": "text",
      "id": "milestone_1",
      "label": "Milestone 1 (start)",
      "default": "2,000+ Years of Tradition"
    },
    {
      "type": "text",
      "id": "milestone_2",
      "label": "Milestone 2",
      "default": "Tested for Purity & Potency"
    },
    {
      "type": "text",
      "id": "milestone_3",
      "label": "Milestone 3",
      "default": "Formulated by Licensed TCM Herbalists"
    },
    {
      "type": "text",
      "id": "milestone_4",
      "label": "Milestone 4",
      "default": "100% Vegan"
    },
    {
      "type": "text",
      "id": "milestone_5",
      "label": "Milestone 5",
      "default": "No Artificials / No Added Sugar"
    },
    {
      "type": "text",
      "id": "milestone_6",
      "label": "Milestone 6 (end)",
      "default": "Zero Sugar"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image",
      "info": "Parchment / paper texture recommended. Falls back to the background color below."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5F0E6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#3B2A1A"
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Line & dot color",
      "default": "#8B5A3C"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "Top space (desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "Bottom space (desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "Top space (mobile)",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "Bottom space (mobile)",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "NAINAI Brand Timeline",
      "category": "NAINAI"
    }
  ]
}
{% endschema %}
